/* ============================================================
   OpenThrall UI v2 — Industrial Terminal
   IBM Plex Mono + DM Sans | Near-black | Amber accent
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg-base:       #0b0d0f;
  --bg-panel:      #0f1214;
  --bg-elevated:   #161a1d;
  --bg-input:      #0d1013;
  --bg-rail:       #0d1013;
  --border:        #1e2428;
  --border-hi:     #2d363d;
  --text-primary:  #cdd6de;
  --text-dim:      #607585;
  --text-muted:    #364550;
  --accent:        #e8a838;
  --accent-dim:    #6b4a18;
  --accent-glow:   rgba(232,168,56,0.08);
  --green:         #4caf7a;
  --red:           #c95a5a;
  --blue:          #4f8fd4;
  --purple:        #9572cc;
  --font-mono:     'IBM Plex Mono', 'Courier New', monospace;
  --font-sans:     'DM Sans', system-ui, sans-serif;
  --radius:        3px;
  --rail-width:    200px;
  --rail-collapsed:52px;
  --toolbar-h:     44px;
  --transition:    110ms ease;
}

html, body, #root {
  height: 100%;
  background: var(--bg-base);
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 13px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-hi); border-radius: 2px; }

/* ── Boot Screen ─────────────────────────────────────────── */

.boot-screen {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  background: var(--bg-base);
}

.boot-logo {
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.18em;
}

.boot-status {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.25em;
  animation: blink 1.4s step-end infinite;
}

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

/* ── App Shell ───────────────────────────────────────────── */

.app-shell {
  height: 100vh;
  display: flex;
  overflow: hidden;
}

.shell-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-width: 0;
}

/* ── Left Rail ───────────────────────────────────────────── */

.left-rail {
  width: var(--rail-width);
  flex-shrink: 0;
  background: var(--bg-rail);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: width 180ms cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  z-index: 10;
}

.left-rail.collapsed {
  width: var(--rail-collapsed);
}

.rail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10px;
  height: var(--toolbar-h);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  gap: 8px;
}

.rail-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  overflow: hidden;
  min-width: 0;
}

.rail-logo-mark {
  font-size: 15px;
  color: var(--accent);
  flex-shrink: 0;
  line-height: 1;
}

.rail-logo-text {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.12em;
  white-space: nowrap;
  overflow: hidden;
}

.rail-toggle {
  background: none;
  border: 1px solid var(--border);
  color: var(--text-dim);
  cursor: pointer;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius);
  flex-shrink: 0;
  transition: all var(--transition);
}

.rail-toggle:hover {
  border-color: var(--border-hi);
  color: var(--text-primary);
  background: var(--bg-elevated);
}

.left-rail.collapsed .rail-header {
  justify-content: center;
  padding: 0;
}

.rail-nav {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 8px 0;
}

.rail-group {
  margin-bottom: 4px;
}

.rail-group-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.22em;
  color: var(--text-muted);
  padding: 10px 14px 4px;
  white-space: nowrap;
  overflow: hidden;
  text-transform: uppercase;
}

.rail-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 7px 12px;
  background: none;
  border: none;
  border-left: 2px solid transparent;
  color: var(--text-dim);
  cursor: pointer;
  text-align: left;
  transition: all var(--transition);
  position: relative;
  white-space: nowrap;
}

.rail-item:hover {
  color: var(--text-primary);
  background: var(--bg-elevated);
}

.rail-item.active {
  color: var(--accent);
  border-left-color: var(--accent);
  background: var(--accent-glow);
}

.rail-item.placeholder {
  opacity: 0.5;
}

.rail-item.placeholder:hover {
  opacity: 0.7;
}

.left-rail.collapsed .rail-item {
  justify-content: center;
  padding: 8px 0;
  border-left: none;
  border-radius: 0;
}

.left-rail.collapsed .rail-item.active {
  background: var(--accent-glow);
}

.rail-item-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 16px;
}

.rail-item-label {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rail-item-soon {
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  border: 1px solid var(--border);
  padding: 1px 4px;
  border-radius: 2px;
  flex-shrink: 0;
}

/* Tooltip for collapsed state */
.left-rail.collapsed .rail-item[title]:hover::after {
  content: attr(title);
  position: absolute;
  left: calc(var(--rail-collapsed) + 4px);
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg-elevated);
  border: 1px solid var(--border-hi);
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 500;
  padding: 4px 10px;
  border-radius: var(--radius);
  white-space: nowrap;
  z-index: 100;
  pointer-events: none;
}

/* ── Top Toolbar ─────────────────────────────────────────── */

.top-toolbar {
  height: var(--toolbar-h);
  display: flex;
  align-items: center;
  background: var(--bg-panel);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  padding: 0 16px 0 4px;
  gap: 0;
  overflow: hidden;
}

.toolbar-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  height: 100%;
}

.toolbar-app-title {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: var(--text-primary);
  padding: 0 16px;
  white-space: nowrap;
  flex-shrink: 0;
}

.toolbar-divider-v {
  width: 1px;
  height: 20px;
  background: var(--border);
  flex-shrink: 0;
}

.toolbar-tabs {
  display: flex;
  align-items: center;
  height: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: none;
}

.toolbar-tabs::-webkit-scrollbar { display: none; }

.toolbar-tab {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 500;
  padding: 0 14px;
  height: 100%;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-dim);
  cursor: pointer;
  white-space: nowrap;
  transition: all var(--transition);
}

.toolbar-tab:hover { color: var(--text-primary); }

.toolbar-tab.active {
  color: var(--text-primary);
  border-bottom-color: var(--accent);
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}

.toolbar-identity {
  display: flex;
  align-items: center;
  gap: 5px;
}

.identity-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  color: var(--text-muted);
}

.identity-name {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-dim);
}

.toolbar-health {
  display: flex;
  align-items: center;
  gap: 8px;
}

.health-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 10px;
  padding: 3px 8px;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  background: var(--bg-elevated);
  color: var(--text-dim);
}

.health-chip.ok   { border-color: rgba(76,175,122,0.25); }
.health-chip.err  { border-color: rgba(201,90,90,0.3); color: var(--red); }
.health-chip.warn { border-color: rgba(232,168,56,0.25); color: var(--accent); }

.health-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.health-chip.ok .health-dot  { background: var(--green); box-shadow: 0 0 4px var(--green); }
.health-chip.err .health-dot { background: var(--red); }
.health-chip.warn .health-dot { background: var(--accent); }

.health-val {
  color: var(--text-primary);
  margin-left: 2px;
}

/* ── Content Area ────────────────────────────────────────── */

.content-area {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--bg-base);
}

.content-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
}

/* ── Placeholder View ────────────────────────────────────── */

.placeholder-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40px;
}

.placeholder-inner {
  text-align: center;
  max-width: 400px;
}

.placeholder-tag {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.3em;
  color: var(--accent);
  border: 1px solid var(--accent-dim);
  display: inline-block;
  padding: 3px 10px;
  border-radius: 2px;
  margin-bottom: 16px;
  background: var(--accent-glow);
}

.placeholder-title {
  font-family: var(--font-mono);
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.08em;
  margin-bottom: 12px;
}

.placeholder-msg {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: 32px;
}

.placeholder-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  max-width: 240px;
  margin: 0 auto;
}

.placeholder-cell {
  height: 32px;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

/* ── Org Layout ──────────────────────────────────────────── */

.org-layout {
  display: flex;
  height: 100%;
  overflow: hidden;
}

.org-tree-wrap {
  width: 280px;
  flex-shrink: 0;
  border-right: 1px solid var(--border);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.org-detail-wrap {
  flex: 1;
  overflow-y: auto;
}

/* ── Data Table View ─────────────────────────────────────── */

.nodes-table-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.view-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-panel);
  flex-shrink: 0;
}

.view-title {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: var(--text-dim);
}

.view-count {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-muted);
  margin-right: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

.data-table th {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  color: var(--text-muted);
  text-align: left;
  padding: 9px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-panel);
  font-weight: 500;
}

.data-table td {
  padding: 9px 16px;
  border-bottom: 1px solid rgba(30,36,40,0.6);
  color: var(--text-primary);
  vertical-align: middle;
}

.data-table tr:hover td {
  background: var(--bg-elevated);
}

.td-primary { font-weight: 500; }
.td-dim     { color: var(--text-dim); }
.td-mono    { font-family: var(--font-mono); font-size: 11px; }

/* ── Control Overview ────────────────────────────────────── */

.control-overview {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
  padding: 20px;
}

.stat-card {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.22em;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.stat-value {
  font-family: var(--font-mono);
  font-size: 18px;
  font-weight: 600;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}

.stat-ok      { color: var(--green); }
.stat-warn    { color: var(--accent); }
.stat-unknown { color: var(--text-dim); }
.stat-mono    { font-size: 12px; color: var(--text-dim); word-break: break-all; }

.stat-detail {
  font-size: 11px;
  color: var(--text-muted);
  word-break: break-all;
}

/* ── Panel Base ──────────────────────────────────────────── */

.panel {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-panel);
  flex-shrink: 0;
}

.panel-title {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: var(--text-dim);
}

.panel-count {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-muted);
  margin-left: auto;
}

.panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

.panel-error {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--red);
  padding: 8px;
  background: rgba(201,90,90,0.07);
  border: 1px solid rgba(201,90,90,0.2);
  border-radius: var(--radius);
  margin-bottom: 8px;
}

.empty-state {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  text-align: center;
  padding: 40px 16px;
}

/* ── Org Tree ────────────────────────────────────────────── */

.tree-body { padding: 8px 0; }

.tree-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 16px;
  cursor: pointer;
  border-radius: 0;
  transition: background var(--transition);
  border-left: 2px solid transparent;
}

.tree-row:hover { background: var(--bg-elevated); }

.tree-row.selected {
  background: var(--accent-glow);
  border-left-color: var(--accent);
}

.tree-connector {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  flex-shrink: 0;
}

.node-badge {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  padding: 2px 6px;
  border-radius: 2px;
  flex-shrink: 0;
}

.node-human   { background: rgba(232,168,56,0.12); color: var(--accent);  border: 1px solid var(--accent-dim); }
.node-coo     { background: rgba(79,143,212,0.1);  color: var(--blue);   border: 1px solid rgba(79,143,212,0.28); }
.node-chief   { background: rgba(149,114,204,0.1); color: var(--purple); border: 1px solid rgba(149,114,204,0.28); }
.node-dept    { background: rgba(76,175,122,0.09); color: var(--green);  border: 1px solid rgba(76,175,122,0.22); }
.node-agent   { background: var(--bg-elevated);    color: var(--text-dim); border: 1px solid var(--border); }
.node-default { background: var(--bg-elevated);    color: var(--text-dim); border: 1px solid var(--border); }

.node-name { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); }
.node-role { font-size: 11px; color: var(--text-muted); }

.node-disabled-tag {
  font-family: var(--font-mono); font-size: 9px; color: var(--red);
  border: 1px solid rgba(201,90,90,0.3); padding: 1px 5px; border-radius: 2px; margin-left: auto;
}

/* ── Node Detail Sidebar ─────────────────────────────────── */

.node-sidebar { height: 100%; display: flex; flex-direction: column; }

.sidebar-header {
  display: flex; align-items: center; padding: 10px 16px;
  border-bottom: 1px solid var(--border); background: var(--bg-panel);
}

.sidebar-title {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em; color: var(--text-dim);
}

.sidebar-body { padding: 16px; display: flex; flex-direction: column; gap: 4px; }

.detail-row {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 7px 0; border-bottom: 1px solid rgba(30,36,40,0.7);
}
.detail-row-block { flex-direction: column; gap: 6px; }
.detail-label {
  font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em;
  color: var(--text-muted); width: 80px; flex-shrink: 0; padding-top: 1px;
}
.detail-value { font-family: var(--font-mono); font-size: 11px; color: var(--text-primary); word-break: break-all; }
.detail-id { color: var(--text-dim); font-size: 10px; }

.status-enabled  { color: var(--green); font-family: var(--font-mono); font-size: 11px; }
.status-disabled { color: var(--red);   font-family: var(--font-mono); font-size: 11px; }

.detail-type-desc {
  margin-top: 16px; font-size: 12px; color: var(--text-dim); line-height: 1.6;
  padding: 12px; background: var(--bg-elevated); border-radius: var(--radius); border: 1px solid var(--border);
}

/* ── Thrall Chat ─────────────────────────────────────────── */

.thrall-chat-panel { height: 100%; }

.chat-participants {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--font-mono); font-size: 10px; margin-left: auto;
}
.participant.human { color: var(--accent); }
.participant.coo   { color: var(--blue); }
.participant-arrow { color: var(--text-muted); }

.chat-messages {
  flex: 1; overflow-y: auto; padding: 16px;
  display: flex; flex-direction: column; gap: 12px;
}

.chat-empty {
  font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);
  text-align: center; margin: auto; padding: 40px;
}

.chat-msg {
  max-width: 82%; border-radius: var(--radius);
  padding: 10px 14px; border: 1px solid var(--border);
}
.chat-msg-human  { align-self: flex-end;  background: rgba(232,168,56,0.06); border-color: rgba(232,168,56,0.18); }
.chat-msg-thrall { align-self: flex-start; background: var(--bg-elevated); }
.chat-msg-error  { align-self: flex-start; background: rgba(201,90,90,0.06); border-color: rgba(201,90,90,0.22); }

.chat-msg-header { display: flex; justify-content: space-between; margin-bottom: 6px; }
.chat-msg-role   { font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: 0.12em; color: var(--text-dim); }
.chat-msg-ts     { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); }
.chat-msg-body   { font-size: 13px; color: var(--text-primary); line-height: 1.6; white-space: pre-wrap; }
.chat-msg-meta   { margin-top: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); }

.thinking-dots { display: inline-flex; gap: 4px; align-items: center; height: 16px; }
.thinking-dots span {
  width: 5px; height: 5px; border-radius: 50%; background: var(--text-dim);
  animation: pulse 1.2s ease-in-out infinite;
}
.thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
.thinking-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse { 0%,100%{opacity:0.3;transform:scale(0.8)} 50%{opacity:1;transform:scale(1)} }

.chat-input-row {
  display: flex; gap: 8px; padding: 12px 16px;
  border-top: 1px solid var(--border); background: var(--bg-panel); flex-shrink: 0;
}
.chat-input {
  flex: 1; background: var(--bg-input); border: 1px solid var(--border);
  color: var(--text-primary); font-family: var(--font-sans); font-size: 13px;
  padding: 8px 12px; border-radius: var(--radius); resize: none; outline: none;
  transition: border-color var(--transition);
}
.chat-input:focus { border-color: var(--accent); }
.chat-send-btn { align-self: flex-end; }

/* ── Approvals ───────────────────────────────────────────── */

.approval-row {
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px; margin-bottom: 8px;
}
.approval-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.approval-kind { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; color: var(--text-primary); font-weight: 600; }
.approval-ts   { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); margin-left: auto; }
.approval-status { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em; padding: 2px 7px; border-radius: 2px; }
.status-PENDING  { background: rgba(232,168,56,0.1); color: var(--accent); border: 1px solid var(--accent-dim); }
.status-APPROVED { background: rgba(76,175,122,0.1); color: var(--green); border: 1px solid rgba(76,175,122,0.28); }
.status-DENIED   { background: rgba(201,90,90,0.08); color: var(--red);   border: 1px solid rgba(201,90,90,0.28); }
.approval-summary { font-size: 12px; color: var(--text-primary); margin-bottom: 8px; line-height: 1.5; }
.approval-id { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); margin-bottom: 10px; word-break: break-all; }
.approval-actions { display: flex; gap: 8px; }
.approval-feedback { font-family: var(--font-mono); font-size: 11px; padding: 6px 10px; border-radius: var(--radius); }
.feedback-ok    { background: rgba(76,175,122,0.08); color: var(--green); border: 1px solid rgba(76,175,122,0.28); }
.feedback-error { background: rgba(201,90,90,0.08); color: var(--red); border: 1px solid rgba(201,90,90,0.28); }

/* ── Events ──────────────────────────────────────────────── */

.events-body { padding: 8px 0; }
.event-row {
  display: grid; grid-template-columns: 70px 170px 1fr; align-items: baseline;
  gap: 10px; padding: 6px 12px; border-bottom: 1px solid rgba(30,36,40,0.5);
}
.event-row:hover { background: var(--bg-elevated); }
.event-ts   { font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); flex-shrink: 0; }
.event-type { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; flex-shrink: 0; }
.evt-create  { color: var(--green); } .evt-update { color: var(--blue); }
.evt-warn    { color: var(--accent); } .evt-approval { color: var(--purple); }
.evt-ok      { color: var(--green); } .evt-deny { color: var(--red); }
.evt-chat    { color: var(--text-dim); } .evt-error { color: var(--red); }
.evt-default { color: var(--text-muted); }
.event-msg  { font-size: 12px; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── Buttons ─────────────────────────────────────────────── */

.btn-primary {
  font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
  background: var(--accent); color: #0b0d0f; border: none;
  padding: 9px 20px; border-radius: var(--radius); cursor: pointer; transition: all var(--transition);
}
.btn-primary:hover:not(:disabled) { background: #efb445; }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-ghost {
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em;
  background: none; color: var(--text-dim); border: 1px solid var(--border);
  padding: 8px 16px; border-radius: var(--radius); cursor: pointer; transition: all var(--transition);
}
.btn-ghost:hover:not(:disabled) { border-color: var(--border-hi); color: var(--text-primary); }
.btn-ghost:disabled { opacity: 0.4; cursor: not-allowed; }
.btn-sm { padding: 4px 10px; font-size: 10px; }

.btn-approve {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
  background: rgba(76,175,122,0.1); color: var(--green);
  border: 1px solid rgba(76,175,122,0.32); padding: 6px 14px; border-radius: var(--radius); cursor: pointer; transition: all var(--transition);
}
.btn-approve:hover:not(:disabled) { background: rgba(76,175,122,0.2); }
.btn-approve:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-deny {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
  background: rgba(201,90,90,0.08); color: var(--red);
  border: 1px solid rgba(201,90,90,0.28); padding: 6px 14px; border-radius: var(--radius); cursor: pointer; transition: all var(--transition);
}
.btn-deny:hover:not(:disabled) { background: rgba(201,90,90,0.18); }
.btn-deny:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-close {
  background: none; border: none; color: var(--text-dim); cursor: pointer;
  font-size: 14px; padding: 4px; line-height: 1; margin-left: auto; transition: color var(--transition);
}
.btn-close:hover { color: var(--text-primary); }

/* ── Status dot (legacy compat) ──────────────────────────── */
.status-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.status-dot.online  { background: var(--green); box-shadow: 0 0 5px var(--green); }
.status-dot.offline { background: var(--red); }
.status-dot.warn    { background: var(--accent); }

/* ── Bootstrap Wizard ────────────────────────────────────── */

.wizard-container {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center; padding: 40px 20px;
  background: radial-gradient(ellipse 55% 35% at 50% -5%, rgba(232,168,56,0.06) 0%, transparent 60%), var(--bg-base);
}

.wizard-header { text-align: center; margin-bottom: 36px; }
.wizard-logo {
  font-family: var(--font-mono); font-size: 22px; font-weight: 600;
  color: var(--accent); letter-spacing: 0.2em; margin-bottom: 6px;
}
.wizard-tagline { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.32em; color: var(--text-muted); }

.wizard-progress { display: flex; align-items: center; margin-bottom: 28px; font-family: var(--font-mono); font-size: 10px; }
.progress-step {
  display: flex; align-items: center; gap: 8px; padding: 6px 14px;
  border: 1px solid var(--border); color: var(--text-muted); letter-spacing: 0.12em; border-radius: var(--radius); transition: all var(--transition);
}
.progress-step.active { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }
.progress-step.done   { border-color: var(--green); color: var(--green); }
.progress-line        { width: 28px; height: 1px; background: var(--border); }

.wiz-step { width: 100%; max-width: 540px; background: var(--bg-panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; }
.wiz-step-header { display: flex; gap: 18px; align-items: flex-start; margin-bottom: 24px; }
.wiz-step-badge { font-family: var(--font-mono); font-size: 28px; font-weight: 600; color: var(--accent); line-height: 1; min-width: 44px; }
.wiz-step-header h2 { font-family: var(--font-mono); font-size: 12px; font-weight: 600; letter-spacing: 0.15em; color: var(--text-primary); margin-bottom: 6px; }
.wiz-step-header p  { font-size: 12px; color: var(--text-dim); line-height: 1.6; }

.form-field { margin-bottom: 18px; }
.form-field label { display: block; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; color: var(--text-dim); margin-bottom: 7px; }
.required { color: var(--accent); }
.optional { color: var(--text-muted); }
.form-field input {
  width: 100%; background: var(--bg-input); border: 1px solid var(--border);
  color: var(--text-primary); font-family: var(--font-mono); font-size: 13px;
  padding: 9px 12px; border-radius: var(--radius); outline: none; transition: border-color var(--transition);
}
.form-field input:focus { border-color: var(--accent); }
.form-field input::placeholder { color: var(--text-muted); }

.wiz-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }

.review-card { background: var(--bg-base); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; margin-bottom: 18px; }
.review-row  { display: flex; align-items: center; gap: 10px; padding: 7px 0; }
.review-connector { font-family: var(--font-mono); color: var(--text-muted); padding: 0 4px; font-size: 12px; }
.review-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--text-dim); width: 120px; flex-shrink: 0; }
.review-value { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); flex: 1; }
.review-badge { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; padding: 2px 7px; border-radius: 2px; }
.review-badge.human  { background: rgba(232,168,56,0.12); color: var(--accent); border: 1px solid var(--accent-dim); }
.review-badge.thrall { background: rgba(79,143,212,0.1); color: var(--blue); border: 1px solid rgba(79,143,212,0.28); }
.review-notice { font-size: 11px; color: var(--text-dim); background: rgba(201,90,90,0.06); border: 1px solid rgba(201,90,90,0.18); border-radius: var(--radius); padding: 9px 13px; margin-bottom: 18px; }

.error-banner {
  display: flex; align-items: center; gap: 12px;
  background: rgba(201,90,90,0.08); border: 1px solid var(--red); border-radius: var(--radius);
  padding: 11px 14px; margin-bottom: 18px; width: 100%; max-width: 540px;
  font-family: var(--font-mono); font-size: 11px; color: var(--red);
}
.error-icon { font-size: 13px; flex-shrink: 0; }
.error-dismiss {
  margin-left: auto; background: none; border: 1px solid var(--red); color: var(--red);
  font-family: var(--font-mono); font-size: 9px; padding: 3px 8px; cursor: pointer;
  border-radius: var(--radius); letter-spacing: 0.1em;
}
